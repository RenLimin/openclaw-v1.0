# ==============================================
# OpenClaw .gitignore v1.0
# ==============================================

# --------------------------
# 敏感信息与密钥
# --------------------------
.env
.env.local
.env.*
secrets/
*.key
*.pem
*.p12
api_keys.json
credentials.json

# --------------------------
# 配置文件（模板保留，实际配置排除）
# --------------------------
core-config/*
!core-config/*.template
!core-config/*.md

# --------------------------
# 临时文件
# --------------------------
*.tmp
*.temp
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --------------------------
# 日志文件
# --------------------------
*.log
logs/
*.log.*

# --------------------------
# Python 相关
# --------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --------------------------
# 虚拟环境
# --------------------------
venv/
env/
ENV/
.venv/

# --------------------------
# 数据库
# --------------------------
*.db
*.sqlite
*.sqlite3

# --------------------------
# 备份文件
# --------------------------
backup/
*.bak
*.backup

# --------------------------
# 测试与覆盖率
# --------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# --------------------------
# IDE
# --------------------------
.idea/
.vscode/
*.swp
*.swo

# --------------------------
# Docker
# --------------------------
docker-compose.override.yml

# --------------------------
# 多租户数据
# --------------------------
tenants/*
!tenants/README.md
!tenants/tenant_template/

# --------------------------
# 记忆与学习数据（可选择是否提交）
# --------------------------
memory/*
!memory/ERRORS.md
!memory/README.md
knowledge-base/*_local.json

# ==============================================
# 版本：v1.0 | 最后更新：2026-05-08
# ==============================================
